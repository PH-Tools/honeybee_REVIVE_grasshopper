"""
This component installs/updates all of the 'Honeybee-REVIVE' plugin libraries for Ladybug Tools.
Please make sure that you have Ladybug-Tools with Honeybee ALREADY fully installed BEFORE
proceeding with this installation. Make sure you are connected to the internet in 
order to download the latest version of the plugin libraries and components.
-
This tool will download and install several new libraries into the Ladybug-Tools
python interpreter, and will download and install new Grasshopper components which
will be added to your Rhino / Grasshopper installation.
-
EM November 1, 2024
    Args:
        _install: (bool) Set to True to install Honeybee-REVIVE on your computer.
        
        _hb_revive_version: (str): The Version number of the Honeybee-REVIVE package to install from PyPi.
            Note that if you leave this input empty, the latest version will be installed. For 
            more details on honeybee-revive version, see https://pypi.org/project/honeybee-REVIVE/
       
        _ph_adorb_version: (str): The Version number of the PH-ADORB package to install from PyPi.
            Note that if you leave this input empty, the latest version will be installed. For 
            more details on PH-ADOPRB version, see https://pypi.org/project/PH-ADORB/
    Returns:
        lbt_python_exe_: The path to the Ladybug-Tools Python interpreter installed on your computer. 

        lbt_python_packages_: The path to the Ladybug-Tools Python packages folder on your computer.

        is_admin_: Are you running in admin mode? This is required for installing Honeybee-REVIVE.
"""

COMPONENT = ghenv.Component # type: ignore
COMPONENT.Name = 'HB-REVIVE Installer'
COMPONENT.NickName = 'HB-REVIVE Installer'
COMPONENT.Message = 'NOV_01_2024'
COMPONENT.Category = 'HB-REVIVE'
COMPONENT.SubCategory = '00 | Utils'
COMPONENT.AdditionalHelpFromDocStrings = '0'

try:
    COMPONENT.ToggleObsolete(False)
except AttributeError:
    pass # Rhino 7
    
